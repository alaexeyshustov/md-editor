{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "@nativescript/types-android"]
  },
  "include": ["app/**/*.ts", "app/**/*.d.ts", "app/**/*.vue", "*.ts"],
  "exclude": ["dist", "node_modules"]
}

